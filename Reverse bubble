#include <iostream>
#include <Windows.h>

int main() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    const int size = 10;
    int integers[size] = { 10, 3, 4, 1, 8, 9, 7, 2, 6, 5 };

    std::cout << "Массив до сортировки: \t";
    for (int i = 0; i < size; i++)
    {
        std::cout << integers[i] << " ";
    }
    std::cout << std::endl;

    for (int i = size - 1; i > 0; i--)  
    {
        for (int j{}; j < i; j++)
        {
            if (integers[j] > integers[j + 1])
            {
                int temporary = integers[j];
                integers[j] = integers[j + 1];
                integers[j + 1] = temporary;
            }
        }
    }

    std::cout << "\nМассив после сортировки: ";
    for (int i{}; i < size; i++)
    {
        std::cout << integers[i] << " ";
    }
    std::cout << std::endl;

    return EXIT_SUCCESS;
}
